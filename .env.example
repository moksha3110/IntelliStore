# ==== Shared / Infra ====
NODE_ENV=development

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=intellistore
POSTGRES_PASSWORD=intellistore_dev_password
POSTGRES_DB=intellistore

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=intellistore
RABBITMQ_PASSWORD=intellistore_dev_password
RABBITMQ_MANAGEMENT_PORT=15672

# MinIO (S3-compatible storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=intellistore
MINIO_ROOT_PASSWORD=intellistore_dev_password
MINIO_BUCKET=intellistore-chunks

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ==== Service Ports ====
API_GATEWAY_PORT=4000
AUTH_SERVICE_PORT=4001
METADATA_SERVICE_PORT=4002
STORAGE_SERVICE_PORT=4003
REPLICATION_SERVICE_PORT=4004
AI_ANALYTICS_SERVICE_PORT=4005
NOTIFICATION_SERVICE_PORT=4006

# ==== Frontend ====
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
